{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C/C++: g++.exe 生成活动文件",
      "type": "cppbuild",
      "command": "g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\bin\\${fileBasenameNoExtension}.exe",
        "-std=c++17",
        "-Wall",
        "-Wextra"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "使用 g++ 链接并生成 C++ 可执行文件。"
    },
    {
      "label": "C/C++: gcc.exe 生成活动文件",
      "type": "cppbuild",
      "command": "gcc.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\bin\\${fileBasenameNoExtension}.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "保留 gcc 任务作为可选项（不再为默认）。"
    }
    ,
    {
      "label": "C/C++: g++.exe 生成 GUI 可执行文件",
      "type": "cppbuild",
      "command": "g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\bin\\${fileBasenameNoExtension}.exe",
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-mwindows"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "使用 g++ 和 -mwindows 构建，生成打开时不弹出控制台的可执行文件。"
    }
  ]
}
