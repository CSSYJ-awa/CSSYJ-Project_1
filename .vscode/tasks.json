{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C/C++: g++.exe 生成活动文件",
      "type": "cppbuild",
      "command": "D:\\Program Files\\msys64\\ucrt64\\bin\\g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\bin\\${fileBasenameNoExtension}.exe",
        "-std=c++17",
        "-Wall",
        "-Wextra"
      ],
      "options": {
        "cwd": "D:\\Program Files\\msys64\\ucrt64\\bin"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "使用 g++ 链接并生成 C++ 可执行文件。"
    },
    {
      "label": "C/C++: gcc.exe 生成活动文件",
      "type": "cppbuild",
      "command": "D:\\Program Files\\msys64\\ucrt64\\bin\\gcc.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\bin\\${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "保留 gcc 任务作为可选项（不再为默认）。"
    }
  ]
}
